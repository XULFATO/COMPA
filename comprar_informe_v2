' --- BOTONES DE CONTROL ---
Sub ImportarHoy1(): ImportarHoja 1: End Sub
Sub ImportarHoy2(): ImportarHoja 2: End Sub

' 1. LIMPIEZA TOTAL (Reset de entorno)
Sub BorrarTodo()
    Dim resp As Integer
    resp = MsgBox("¿Desea limpiar el libro por completo?", vbQuestion + vbYesNo, "Limpieza de Seguridad")
    If resp = vbNo Then Exit Sub
    
    Application.DisplayAlerts = False
    Dim ws As Worksheet
    For Each ws In ThisWorkbook.Worksheets
        If ws.Name <> "MENU" Then ws.Delete
    Next ws
    ThisWorkbook.Worksheets("MENU").Range("J1:J2").ClearContents
    Application.DisplayAlerts = True
End Sub

' 2. IMPORTACIÓN (Tratamiento de Texto desde el Origen)
Sub ImportarHoja(slot As Integer)
    Dim wsM As Worksheet: Set wsM = ThisWorkbook.Worksheets("MENU")
    Dim wbLoop As Workbook, nombres() As String, n As Integer: n = 0
    
    For Each wbLoop In Application.Workbooks
        If wbLoop.Name <> ThisWorkbook.Name Then
            ReDim Preserve nombres(n): nombres(n) = wbLoop.Name: n = n + 1
        End If
    Next wbLoop
    
    If n = 0 Then MsgBox "No hay archivos abiertos para importar.", vbExclamation: Exit Sub
    
    Dim resp As Variant: resp = Application.InputBox("Seleccione archivo (1-" & n & "):", "Slot " & slot, Type:=1)
    If VarType(resp) = vbBoolean Then Exit Sub
    
    Dim wbO As Workbook: Set wbO = Application.Workbooks(nombres(CInt(resp) - 1))
    Dim nomH As String: nomH = "Hoja_v" & slot
    
    Application.DisplayAlerts = False
    On Error Resume Next: ThisWorkbook.Worksheets(nomH).Delete: On Error GoTo 0
    
    ' Copiamos la hoja original
    wbO.Worksheets(1).Copy After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count)
    
    With ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count)
        .Name = nomH
        ' --- CRÍTICO: Forzamos formato Texto para no perder 00001 ---
        .Cells.NumberFormat = "@" 
    End With
    
    If slot = 1 Then wsM.Range("J1").Value = nomH Else wsM.Range("J2").Value = nomH
    wsM.Activate: Application.DisplayAlerts = True
End Sub

' 3. COMPARAR (Lógica Espejo V1 + Auditoría de IDs)
Sub CompararHojas()
    Dim wsM As Worksheet: Set wsM = ThisWorkbook.Worksheets("MENU")
    Dim nH1 As String: nH1 = Trim(wsM.Range("J1").Value)
    Dim nH2 As String: nH2 = Trim(wsM.Range("J2").Value)
    
    If nH1 = "" Or nH2 = "" Then MsgBox "Faltan hojas por importar.", vbCritical: Exit Sub
    
    Dim ws1 As Worksheet: Set ws1 = ThisWorkbook.Worksheets(nH1)
    Dim ws2 As Worksheet: Set ws2 = ThisWorkbook.Worksheets(nH2)
    
    ' Identificar columna ID mediante búsqueda visual exacta
    Dim colID1 As Long, colID2 As Long, c As Long
    For c = 1 To ws1.Cells(1, 255).End(xlToLeft).Column
        If LCase(Trim(ws1.Cells(1, c).Text)) = "* employee id" Then colID1 = c: Exit For
    Next
    For c = 1 To ws2.Cells(1, 255).End(xlToLeft).Column
        If LCase(Trim(ws2.Cells(1, c).Text)) = "* employee id" Then colID2 = c: Exit For
    Next
    
    If colID1 = 0 Or colID2 = 0 Then MsgBox "Error: Columna '* Employee ID' no encontrada.", vbCritical: Exit Sub

    ' Crear COMPARACION
    Application.ScreenUpdating = False
    On Error Resume Next: ThisWorkbook.Worksheets("COMPARACION").Delete: On Error GoTo 0
    Dim wsC As Worksheet: Set wsC = ThisWorkbook.Worksheets.Add(After:=wsM)
    wsC.Name = "COMPARACION"
    wsC.Cells.NumberFormat = "@" ' Bloqueo de formato Texto

    ' Cabeceras idénticas a V1
    Dim lastCol1 As Long: lastCol1 = ws1.Cells(1, 255).End(xlToLeft).Column
    wsC.Cells(1, 1) = "FILTRO": wsC.Range("A1:A2").Merge
    wsC.Cells(1, 1).Interior.Color = RGB(197, 90, 17)
    
    For c = 1 To lastCol1
        Dim colD As Long: colD = (c - 1) * 2 + 2
        wsC.Range(wsC.Cells(1, colD), wsC.Cells(1, colD + 1)).Merge
        wsC.Cells(1, colD) = ws1.Cells(1, c).Text 
        wsC.Cells(2, colD) = "BULK ANTERIOR"
        wsC.Cells(2, colD + 1) = "BULK ACTUAL"
    Next
    With wsC.Rows("1:2"): .Font.Bold = True: .Font.Color = vbWhite: .Interior.Color = RGB(31, 78, 121): .HorizontalAlignment = xlCenter: End With

    ' --- PROCESO DE CRUCE DE DATOS ---
    Dim lr2 As Long: lr2 = ws2.Cells(Rows.Count, colID2).End(xlUp).Row
    Dim fD As Long: fD = 3: Dim r1 As Variant, id As String
    
    For r2 = 2 To lr2
        id = Trim(ws2.Cells(r2, colID2).Text) ' Uso de .Text para capturar ceros
        If id <> "" Then
            r1 = Application.Match(id, ws1.Columns(colID1), 0)
            
            If IsError(r1) Then
                ' CASO: NUEVO REGISTRO
                wsC.Cells(fD, 1).Value = "SOLO EN V2": wsC.Cells(fD, 1).Interior.Color = RGB(21, 101, 71)
                wsC.Range(wsC.Cells(fD, 2), wsC.Cells(fD, lastCol1 * 2 + 1)).Interior.Color = RGB(198, 239, 206)
                For c = 1 To lastCol1
                    Dim colOrig2 As Variant: colOrig2 = Application.Match(ws1.Cells(1, c).Text, ws2.Rows(1), 0)
                    If Not IsError(colOrig2) Then wsC.Cells(fD, (c - 1) * 2 + 3).Value = ws2.Cells(r2, colOrig2).Text
                Next
            Else
                ' CASO: COMPARAR CAMPOS
                Dim dif As Boolean: dif = False
                For c = 1 To lastCol1
                    Dim v1 As String: v1 = ws1.Cells(r1, c).Text
                    Dim colV2 As Variant: colV2 = Application.Match(ws1.Cells(1, c).Text, ws2.Rows(1), 0)
                    Dim v2 As String: If Not IsError(colV2) Then v2 = ws2.Cells(r2, colV2).Text Else v2 = ""
                    
                    Dim cIdx As Long: cIdx = (c - 1) * 2 + 2
                    wsC.Cells(fD, cIdx).Value = v1: wsC.Cells(fD, cIdx + 1).Value = v2
                    
                    If v1 <> v2 Then
                        dif = True
                        wsC.Cells(fD, cIdx).Interior.Color = RGB(255, 199, 199) ' Rojo Claro
                        wsC.Cells(fD, cIdx + 1).Interior.Color = RGB(139, 0, 0): wsC.Cells(fD, cIdx + 1).Font.Color = vbWhite
                    End If
                Next
                wsC.Cells(fD, 1).Value = IIf(dif, "DIFERENTES", "IGUALES")
                wsC.Cells(fD, 1).Interior.Color = IIf(dif, RGB(192, 57, 43), RGB(39, 120, 56))
            End If
            fD = fD + 1
        End If
    Next

    wsC.Columns.AutoFit
    wsC.Activate: wsC.Range("B3").Select: ActiveWindow.FreezePanes = True
    Application.ScreenUpdating = True: MsgBox "Auditoría finalizada. Estructura V1 replicada.", vbInformation
End Sub

' 4. EXPORTAR (Blindaje de ceros en libro nuevo)
Sub ExportarDiferenciasV2()
    Dim wsC As Worksheet: On Error Resume Next: Set wsC = ThisWorkbook.Worksheets("COMPARACION"): On Error GoTo 0
    If wsC Is Nothing Then Exit Sub
    
    Application.ScreenUpdating = False
    Dim wbN As Workbook: Set wbN = Workbooks.Add: Dim wsN As Worksheet: Set wsN = wbN.Sheets(1)
    
    ' Bloqueo de formato Texto en el destino antes de recibir datos
    wsN.Cells.NumberFormat = "@"
    
    wsC.Rows("1:2").Copy: wsN.Range("A1").PasteSpecial xlPasteAll
    
    Dim lrC As Long: lrC = wsC.Cells(Rows.Count, 1).End(xlUp).Row
    Dim fDest As Long: fDest = 3
    
    For i = 3 To lrC
        If wsC.Cells(i, 1).Value = "DIFERENTES" Then
            wsC.Rows(i).Copy
            wsN.Rows(fDest).PasteSpecial xlPasteAll
            fDest = fDest + 1
        End If
    Next
    
    If fDest = 3 Then
        wbN.Close False: MsgBox "No hay diferencias marcadas.", vbInformation: Exit Sub
    End If
    
    wsN.Name = "Diferencias_" & Format(Date, "ddmmyy")
    wsN.Columns.AutoFit
    Application.CutCopyMode = False: Application.ScreenUpdating = True
    MsgBox "Exportación exitosa en libro independiente.", vbInformation
End Sub
